{
  "info": {
    "name": "CozyBooking API",
    "description": "Полный сценарий демонстрации backend аренды жилья.\n\nПорядок запуска (сверху вниз):\n1. Auth → Register Lessor, Register Renter, Login Lessor, Login Renter\n   (логины сами сохраняют токены в переменные коллекции)\n2. Listings → Create Listing (сохраняет listing_id), затем каталог/карточка/и т.д.\n3. Reservations → Create (сохраняет reservation_id), Confirm, Check-in\n4. Reviews → Create Review, Listing Reviews\n\nПеременная base_url по умолчанию http://127.0.0.1:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Lessor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/users/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Host Johan\",\n  \"email\": \"l1@test.de\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"LESSOR\"\n}"
            }
          }
        },
        {
          "name": "Register Renter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/users/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Guest Alex\",\n  \"email\": \"r1@test.de\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"RENTER\"\n}"
            }
          }
        },
        {
          "name": "Login Lessor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.collectionVariables.set(\"access_lessor\", jsonData.access);",
                  "}",
                  "if (jsonData.user && jsonData.user.id) {",
                  "    pm.collectionVariables.set(\"lessor_user_id\", jsonData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/users/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"l1@test.de\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        },
        {
          "name": "Login Renter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.collectionVariables.set(\"access_renter\", jsonData.access);",
                  "}",
                  "if (jsonData.user && jsonData.user.id) {",
                  "    pm.collectionVariables.set(\"renter_user_id\", jsonData.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/users/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"r1@test.de\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Listings",
      "item": [
        {
          "name": "Create Listing (lessor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set(\"listing_id\", jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_lessor}}"
              }
            ],
            "url": "{{base_url}}/api/listings/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Modern Studio near City Center\",\n  \"description\": \"Beautiful and bright apartment fully furnished.\",\n  \"price\": 1200,\n  \"rooms\": 2,\n  \"housing_type\": \"STUDIO\",\n  \"address\": {\n    \"land\": \"Steiermark\",\n    \"city\": \"Graz\",\n    \"street\": \"Georgigasse 87\",\n    \"postal_code\": \"8020\"\n  }\n}"
            }
          }
        },
        {
          "name": "Catalog (public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/listings/"
          }
        }
      ]
    },
    {
      "name": "3. Reservations",
      "item": [
        {
          "name": "Create Reservation (renter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set(\"reservation_id\", jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_renter}}"
              }
            ],
            "url": "{{base_url}}/api/reservations/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listing\": {{listing_id}},\n  \"start_date\": \"2026-08-01\",\n  \"end_date\": \"2026-08-15\"\n}"
            }
          }
        },
        {
          "name": "Confirm (lessor)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_lessor}}"
              }
            ],
            "url": "{{base_url}}/api/reservations/{{reservation_id}}/status/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            }
          }
        },
        {
          "name": "Check-in (lessor)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_lessor}}"
              }
            ],
            "url": "{{base_url}}/api/reservations/{{reservation_id}}/status/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CHECKED_IN\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Reviews",
      "item": [
        {
          "name": "Create Review (renter)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_renter}}"
              }
            ],
            "url": "{{base_url}}/api/reviews/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation\": {{reservation_id}},\n  \"rating\": 5,\n  \"comment\": \"Everything was perfect! Cozy and neat!\"\n}"
            }
          }
        },
        {
          "name": "Listing Reviews (public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/reviews/listing/{{listing_id}}/"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_lessor", "value": "" },
    { "key": "access_renter", "value": "" },
    { "key": "listing_id", "value": "" },
    { "key": "reservation_id", "value": "" },
    { "key": "lessor_user_id", "value": "" },
    { "key": "renter_user_id", "value": "" }
  ]
}