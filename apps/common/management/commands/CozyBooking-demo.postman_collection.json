{
  "info": {
    "name": "CozyBooking API v1",
    "description": "Актуальная Postman-коллекция для CozyBooking (июль 2026).\n\nПорядок:\n1. Auth (register + login)\n2. Listings (create + catalog)\n3. Reservations\n4. Reviews\n\nbase_url = http://127.0.0.1:8000\nversion = v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Lessor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/{{version}}/users/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Host Johan\",\n  \"email\": \"l1@test.de\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"LESSOR\"\n}"
            }
          }
        },
        {
          "name": "Register Renter",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/{{version}}/users/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Guest Alex\",\n  \"email\": \"r1@test.de\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"RENTER\"\n}"
            }
          }
        },
        {
          "name": "Login Lessor",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "if (json.access) pm.collectionVariables.set(\"access_lessor\", json.access);",
                "if (json.user?.id) pm.collectionVariables.set(\"lessor_user_id\", json.user.id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/{{version}}/users/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"l1@test.de\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        },
        {
          "name": "Login Renter",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "if (json.access) pm.collectionVariables.set(\"access_renter\", json.access);",
                "if (json.user?.id) pm.collectionVariables.set(\"renter_user_id\", json.user.id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/{{version}}/users/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"r1@test.de\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_lessor}}" }
            ],
            "url": "{{base_url}}/api/{{version}}/users/logout/",
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Listings",
      "item": [
        {
          "name": "Create Listing (Lessor)",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test(\"201\", () => pm.response.to.have.status(201));", "pm.collectionVariables.set(\"listing_id\", pm.response.json().id);"] }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_lessor}}" }
            ],
            "url": "{{base_url}}/api/{{version}}/listings/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Modern Studio\",\n  \"description\": \"Cozy place\",\n  \"price\": 1200,\n  \"rooms\": 2,\n  \"housing_type\": \"STUDIO\",\n  \"address\": {\n    \"land\": \"Steiermark\",\n    \"city\": \"Graz\",\n    \"street\": \"Georgigasse 87\",\n    \"postal_code\": \"8020\"\n  }\n}"
            }
          }
        },
        {
          "name": "Catalog (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/{{version}}/listings/"
          }
        },
        {
          "name": "My Listings (Lessor)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_lessor}}" }],
            "url": "{{base_url}}/api/{{version}}/listings/my/"
          }
        },
        {
          "name": "Listing Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/{{version}}/listings/{{listing_id}}/"
          }
        }
      ]
    },
    {
      "name": "3. Reservations",
      "item": [
        {
          "name": "Create Reservation (Renter)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test(\"201\", () => pm.response.to.have.status(201));", "pm.collectionVariables.set(\"reservation_id\", pm.response.json().id);"] } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_renter}}" }
            ],
            "url": "{{base_url}}/api/{{version}}/reservations/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listing\": {{listing_id}},\n  \"start_date\": \"2026-08-01\",\n  \"end_date\": \"2026-08-15\"\n}"
            }
          }
        },
        {
          "name": "Confirm (Lessor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_lessor}}" }
            ],
            "url": "{{base_url}}/api/{{version}}/reservations/{{reservation_id}}/confirm/"
          }
        },
        {
          "name": "Check-in (Lessor)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_lessor}}" }],
            "url": "{{base_url}}/api/{{version}}/reservations/{{reservation_id}}/check-in/"
          }
        },
        {
          "name": "Cancel (Renter)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_renter}}" }],
            "url": "{{base_url}}/api/{{version}}/reservations/{{reservation_id}}/cancel/"
          }
        },
        {
          "name": "My Reservations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_renter}}" }],
            "url": "{{base_url}}/api/{{version}}/reservations/my/"
          }
        }
      ]
    },
    {
      "name": "4. Reviews",
      "item": [
        {
          "name": "Create Review (Renter)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_renter}}" }
            ],
            "url": "{{base_url}}/api/{{version}}/reviews/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation\": {{reservation_id}},\n  \"rating\": 5,\n  \"comment\": \"Perfect stay!\"\n}"
            }
          }
        },
        {
          "name": "Listing Reviews (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/{{version}}/reviews/listing/{{listing_id}}/"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "version", "value": "v1" },
    { "key": "access_lessor", "value": "" },
    { "key": "access_renter", "value": "" },
    { "key": "listing_id", "value": "" },
    { "key": "reservation_id", "value": "" }
  ]
}