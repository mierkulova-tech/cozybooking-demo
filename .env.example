# ==================== CozyBooking - Environment Variables ====================

# === General Settings ===
DEBUG=True
TESTING=False

# Secret key - generate a new one locally with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-long-random-secret-key-for-development

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# === Database ===
# Set to True for PostgreSQL (Docker / Render), False for SQLite (local development)
postgresql=False

# PostgreSQL settings (only used when postgresql=True)
# DB_NAME=cozybooking
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=db
# DB_PORT=5432